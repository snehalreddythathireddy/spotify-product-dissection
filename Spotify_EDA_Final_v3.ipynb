        "axes[0].set_xlabel('Popularity (0–100)')\n",
        "axes[0].set_ylabel('Number of Tracks')\n",
        "\n",
        "# KDE plot\n",
        "df['popularity'].plot.kde(ax=axes[1], color='#1DB954', linewidth=2.5)\n",
