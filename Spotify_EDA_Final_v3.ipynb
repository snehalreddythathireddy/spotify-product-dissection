      },
      "execution_count": null,
      "outputs": [],
      "source": [
        "# Chart 1: Distribution of Popularity Score\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
        "\n",
        "# Histogram\n",
        "axes[0].hist(df['popularity'], bins=50, color='#1DB954', edgecolor='white', alpha=0.85)\n",
